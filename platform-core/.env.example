APP_NAME=Torilaure Intelligence OS
API_PREFIX=/api/v1
JWT_SECRET_KEY=change-this-local-dev-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=900
