APP_NAME=Torilaure Intelligence OS
API_PREFIX=/api/v1
JWT_SECRET_KEY=replace-with-a-long-random-local-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=900
REFRESH_TOKEN_EXPIRE_SECONDS=604800
DATABASE_URL=postgresql+psycopg://app_user:change-me-local-dev@localhost:5432/app_db
REDIS_URL=redis://localhost:6379/0
BOOTSTRAP_SAMPLE_DATA=false
BOOTSTRAP_AUTH_USERS=false
